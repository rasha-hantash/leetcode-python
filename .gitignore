__pycache__
.venv/
.pytest_cache/
*.egg-info/

# macOS metadata
.DS_Store

# Obsidian local config — personal layout + vendored plugins, not project-wide
.obsidian/

# Runtime data — generated by recall_engine, regenerated on every recompute.
prep-data/
today.md
today.pdf

# Personal working state — seeded from curriculum.template.md via `prep init`.
# Holds your `[x]` ticks, ✅ stamps, and 📅 schedules; never committed.
curriculum.md

# Your solutions — keep them private. The dir is recreated by `prep init`.
# Company-question prompts (the .md files under problems/company/) stay tracked
# because the curriculum links to them; only your code is ignored.
problems/
!problems/company/
!problems/company/**
